{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DAAIFL Workbench",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}",
      "args": [
        "bit_data_workbench.main:app",
        "--app-dir",
        "${workspaceFolder}\\bdw",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "env": {
        "PORT": "8000",
        "MAX_RESULT_ROWS": "200",
        "DUCKDB_DATABASE": "${workspaceFolder}\\workspace\\bit-data-workbench.f5.duckdb",
        "DUCKDB_EXTENSION_DIRECTORY": "${workspaceFolder}\\.local\\bdw\\duckdb\\extensions",
        "S3_ENDPOINT": "localhost:9000",
        "S3_REGION": "us-east-1",
        "S3_BUCKET": "vat-smoke-test",
        "S3_ACCESS_KEY_ID": "minioadmin",
        "S3_SECRET_ACCESS_KEY": "minioadmin",
        "S3_URL_STYLE": "path",
        "S3_USE_SSL": "false",
        "S3_VERIFY_SSL": "false",
        "S3_STARTUP_VIEW_SCHEMA": "s3",
        "S3_STARTUP_VIEWS": "vat_smoke=csv:s3://vat-smoke-test/startup/vat_smoke.csv",
        "PG_HOST": "localhost",
        "PG_PORT": "5432",
        "PG_USER": "evo1",
        "PG_PASSWORD": "evo1",
        "PG_OLTP_DATABASE": "evo1_oltp",
        "PG_OLAP_DATABASE": "evo1_olap"
      },
      "console": "integratedTerminal",
      "jinja": true,
      "preLaunchTask": "bdw: start local dependencies",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Uvicorn running on .*",
        "uriFormat": "http://127.0.0.1:8000"
      }
    }
  ]
}
